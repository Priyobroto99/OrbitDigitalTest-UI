# --- Test role accounts (seed/known accounts) ---
# Photolab admin console, invoices, migrations
ADMIN_USERNAME=your_username
ADMIN_PASSWORD=your_password

# Studio dashboard, lab orders, customer orders
STUDIO_USERNAME=
STUDIO_PASSWORD=

# Dealer ordering (regression RBAC cross-checks)
DEALER_USERNAME=
DEALER_PASSWORD=

# Partner the ADMIN places a manual order for in the S8/S9 money-path checks.
# Defaults to STUDIO_USERNAME / DEALER_USERNAME when left blank.
STUDIO_PARTNER_USERNAME=
DEALER_PARTNER_USERNAME=

# --- Gallery viewer ---
# Numeric DB id for the test gallery event (used for direct URL navigation, e.g. /aigallery/12).
GALLERY_EVENT_ID=
# Alphanumeric gallery code (e.g. A3K9X2M7) used by the guest finder search box.
GALLERY_EVENT_CODE=
# Display name of the test event as it appears on the gallery index card (e.g. TestEvent).
GALLERY_EVENT_NAME=
# Password to unlock the test gallery event.
GALLERY_EVENT_PASSWORD=

# Optional second event id, used by R22 (event-token cross-scoping).
GALLERY_EVENT_ID_B=
